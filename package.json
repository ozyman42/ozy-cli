{
  "name": "@ozyman42/ozy-cli",
  "version": "0.3.0",
  "description": "Ozymandias' personal tools",
  "type": "module",
  "bin": {
    "ozy": "dist/entrypoints/ozy.js",
    "ozy-signing-agent": "dist/entrypoints/ozy-signing-agent.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun src/scripts/kill-existing-agent.ts && bun src/scripts/build.ts",
    "prepublishOnly": "bun run build",
    "prepare": "[ \"$CI\" = \"true\" ] || lefthook install"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "@types/bs58": "^5.0.0",
    "@types/bun": "^1.3.14",
    "@types/expand-tilde": "^2.0.2",
    "lefthook": "latest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ozyman42/ozy-cli.git"
  },
  "dependencies": {
    "@effect/platform-bun": "^4.0.0-beta.70",
    "bs58": "^6.0.0",
    "commander": "^13.1.0",
    "effect": "4.0.0-beta.70",
    "effective-modules": "0.3.1-effect4",
    "expand-tilde": "^2.0.2",
    "ssh-config": "^5.0.3",
    "zod": "^3.24.2"
  }
}
