{
  "name": "@ozyman42/ozy-cli",
  "version": "0.4.5",
  "description": "Ozymandias' personal tools",
  "type": "module",
  "bin": {
    "ozy": "dist/ozy",
    "ozy-signing-agent": "dist/ozy-signing-agent",
    "ozy-virtual-security-key": "dist/ozy-virtual-security-key",
    "ozy-ssh-keygen": "dist/ozy-ssh-keygen"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "jive:cicd:build": "bun src/scripts/build.ts",
    "jive:cicd:unit-tests": "echo \"No unit tests at this time\"",
    "jive:cicd:upload-artifacts": "echo \"No artifacts to upload\"",
    "jive:cicd:deploy": "echo \"publishing to npm\"",
    "build": "bun src/scripts/kill-existing-agent.ts && bun src/scripts/build.ts",
    "prepublishOnly": "bun run build",
    "prepare": "[ \"$CI\" = \"true\" ] || lefthook install"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "@types/bs58": "^5.0.0",
    "@types/bun": "^1.3.14",
    "@types/expand-tilde": "^2.0.2",
    "lefthook": "latest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ozyman42/ozy-cli.git"
  },
  "dependencies": {
    "@effect/platform-bun": "^4.0.0-beta.70",
    "@ozyman42/interactive-cli-select": "^0.2.0",
    "bip39": "^3.1.0",
    "bs58": "^6.0.0",
    "commander": "^13.1.0",
    "effect": "4.0.0-beta.70",
    "effective-modules": "0.3.1-effect4",
    "expand-tilde": "^2.0.2",
    "friendly-words": "^1.3.1",
    "ssh-config": "^5.0.3",
    "zod": "^3.24.2"
  }
}
