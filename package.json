  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ozyman42/ozy-cli.git"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "effect": "^3.19.16",
    "expand-tilde": "^2.0.2",
    "ssh-config": "^5.0.3",
    "zod": "^3.24.2"
  }
}
