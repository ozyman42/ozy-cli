{
  "name": "@ozyman42/ozy-cli",
  "version": "0.0.5",
  "description": "Ozymandias' personal tools",
  "type": "module",
  "bin": {
    "ozy": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun src/scripts/build.ts",
    "prepublishOnly": "bun run build",
