{
  "name": "@ozyman42/ozy-cli",
  "version": "0.4.6",
  "license": "MIT",
  "description": "Tools for setting up new packages, configuring with git & npm",
  "type": "module",
  "scripts": {
    "jive:cicd:build": "bun src/scripts/build.ts",
    "jive:cicd:unit-tests": "echo \"No unit tests\"",
    "jive:cicd:upload-artifacts": "bun src/scripts/publish.ts",
    "jive:cicd:deploy": "echo \"No deployments\"",
    "build": "bun src/scripts/kill-existing-agent.ts && bun src/scripts/build.ts",
    "prepare": "[ \"$CI\" = \"true\" ] || lefthook install"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "@types/bs58": "^5.0.0",
    "@types/bun": "^1.3.14",
    "@types/ejs": "^3.1.5",
    "@types/expand-tilde": "^2.0.2",
    "@types/friendly-words": "^1.2.2",
    "ejs": "^6.0.1",
    "jsonc-parser": "^3.3.1",
    "lefthook": "latest",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ozyman42/ozy-cli.git"
  },
  "dependencies": {
    "@effect/platform-bun": "^4.0.0-beta.70",
    "@ozyman42/interactive-cli-select": "^0.2.0",
    "bip39": "^3.1.0",
    "bs58": "^6.0.0",
    "commander": "^13.1.0",
    "effect": "4.0.0-beta.70",
    "effective-modules": "0.3.1-effect4",
    "expand-tilde": "^2.0.2",
    "friendly-words": "^1.3.1",
    "ssh-config": "^5.0.3",
    "zod": "^3.24.2"
  }
}
